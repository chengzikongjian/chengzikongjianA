import type { Badge, CharacterItem, Lesson, LevelId, Story } from './types'
import { charData } from './utils/charData'

export const levels: Array<{ id: LevelId; title: string; description: string; color: string }> = [
  { id: 'sprout', title: '启蒙识字', description: '从身边的人和自然开始', color: '#32b67a' },
  { id: 'bridge', title: '幼小衔接', description: '把常见事物连成小句子', color: '#f5a524' },
  { id: 'grade1', title: '一年级基础', description: '校园、时间和动作词', color: '#3a86ff' },
  { id: 'grade2', title: '二年级提升', description: '更丰富的观察和表达', color: '#ef476f' },
  { id: 'grade34', title: '三四年级拓展', description: '阅读里的常用字词', color: '#7b61ff' },
  { id: 'grade56', title: '五六年级积累', description: '面向长文阅读和写作', color: '#118ab2' },
]

const makeCharacter = (
  id: string,
  char: string,
  pinyin: string,
  imageGlyph: string,
  meaning: string,
  words: string[],
  sentences: string[],
  level: LevelId,
  tags: string[],
): CharacterItem => ({
  id,
  char,
  pinyin: charData[char]?.pinyin ?? pinyin,
  imageGlyph,
  meaning,
  words,
  sentences,
  radical: tags[0] ?? '基础',
  structure: char.length === 1 ? '独体/合体识别' : '组合字形',
  strokeCount: charData[char]?.strokes ?? Math.max(1, char.codePointAt(0)! % 18),
  mistakeNote: `注意“${char}”在词语“${words[0]}”中的读音和字形。`,
  pictographHint: `${imageGlyph} -> ${char}`,
  level,
  tags,
  strokeKey: char,
})

